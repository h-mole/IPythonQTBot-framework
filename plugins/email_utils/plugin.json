{
  "name": "email_utils",
  "description": "邮箱工具 - 提供邮件收发、管理和预览功能",
  "version": "1.0.0",
  "author": "IPythonQTBot Team",
  "main": "main",
  "dependencies": [],
  "exports": {
    "namespace": "email_utils",
    "description": "邮箱管理核心组件",
    "methods": [
      {
        "name": "get_recent_emails",
        "description": "API: 获取最近的邮件列表",
        "stable": true,
        "parameters": [
          {
            "name": "account_name",
            "type": "str",
            "description": "账号名称",
            "required": true
          },
          {
            "name": "limit",
            "type": "int",
            "description": "获取邮件数量限制，默认为 20",
            "required": false,
            "default": 20
          },
          {
            "name": "days",
            "type": "int",
            "description": "获取多少天内的邮件，默认为 None（不限制天数）",
            "required": false,
            "default": null
          }
        ],
        "returns": {
          "type": "any",
          "description": ""
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "get_email_detail",
        "description": "API: 获取邮件详情",
        "stable": true,
        "parameters": [
          {
            "name": "account_name",
            "type": "any",
            "description": "账号名称",
            "required": true
          },
          {
            "name": "email_id",
            "type": "any",
            "description": "邮件 ID",
            "required": true
          }
        ],
        "returns": {
          "type": "any",
          "description": ""
        }
      },
      {
        "name": "send_email",
        "description": "API: 发送邮件",
        "stable": true,
        "parameters": [
          {
            "name": "account_name",
            "type": "str",
            "description": "账号名称",
            "required": true
          },
          {
            "name": "to",
            "type": "str",
            "description": "收件人邮箱（多个用逗号分隔）",
            "required": true
          },
          {
            "name": "subject",
            "type": "str",
            "description": "邮件主题",
            "required": true
          },
          {
            "name": "body",
            "type": "str",
            "description": "邮件正文（HTML 格式）",
            "required": true
          },
          {
            "name": "attachments",
            "type": "list",
            "description": "附件文件路径列表",
            "required": false,
            "default": null
          }
        ],
        "returns": {
          "type": "any",
          "description": ""
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "reply_email",
        "description": "API: 回复邮件",
        "stable": true,
        "parameters": [
          {
            "name": "account_name",
            "type": "str",
            "description": "账号名称",
            "required": true
          },
          {
            "name": "original_email_id",
            "type": "str",
            "description": "原邮件ID",
            "required": true
          },
          {
            "name": "body",
            "type": "str",
            "description": "回复的正文内容（HTML 格式）",
            "required": true
          },
          {
            "name": "attachments",
            "type": "list",
            "description": "附件文件路径列表",
            "required": false,
            "default": null
          }
        ],
        "returns": {
          "type": "any",
          "description": ""
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "get_attachments",
        "description": "API: 获取邮件附件列表",
        "stable": true,
        "parameters": [
          {
            "name": "account_name",
            "type": "any",
            "description": "账号名称",
            "required": true
          },
          {
            "name": "email_id",
            "type": "any",
            "description": "邮件 ID",
            "required": true
          }
        ],
        "returns": {
          "type": "any",
          "description": ""
        }
      },
      {
        "name": "download_attachment",
        "description": "API: 下载附件",
        "stable": true,
        "parameters": [
          {
            "name": "account_name",
            "type": "any",
            "description": "账号名称",
            "required": true
          },
          {
            "name": "email_id",
            "type": "any",
            "description": "邮件 ID",
            "required": true
          },
          {
            "name": "filename",
            "type": "any",
            "description": "附件文件名",
            "required": true
          },
          {
            "name": "save_path",
            "type": "any",
            "description": "保存路径",
            "required": true
          }
        ],
        "returns": {
          "type": "any",
          "description": ""
        }
      },
      {
        "name": "get_accounts",
        "description": "API: 获取所有配置的邮箱账号",
        "stable": true,
        "parameters": [],
        "returns": {
          "type": "any",
          "description": ""
        },
        "extra_data": {
          "enable_mcp": true
        }
      }
    ]
  },
  "callbacks": {
    "on_load": "load_plugin",
    "on_unload": "unload_plugin"
  },
  "tabs": [
    {
      "name": "📧 邮箱管理",
      "class": "EmailManagerTab",
      "position": 2
    }
  ]
}