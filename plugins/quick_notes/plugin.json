{
  "name": "quick_notes",
  "description": "快速笔记插件 - 支持树状结构管理的笔记编辑器",
  "version": "1.0.0",
  "author": "IPythonQTBot Team",
  "main": "main",
  "exports": {
    "namespace": "quick_notes",
    "description": "快速笔记核心 API",
    "methods": [
      {
        "name": "create_note",
        "description": "创建新笔记",
        "stable": true,
        "parameters": [
          {
            "name": "name",
            "type": "str",
            "description": "笔记名称",
            "required": true
          },
          {
            "name": "folder",
            "type": "str",
            "description": "所属文件夹路径（可选）,只接受相对路径",
            "required": false
          }
        ],
        "returns": {
          "type": "str",
          "description": "返回创建的笔记完整路径"
        }
      },
      {
        "name": "load_note_to_ipython",
        "description": "加载笔记内容到IPython",
        "stable": true,
        "parameters": [
          {
            "name": "variable_name",
            "type": "str",
            "description": "笔记内容保存的变量名",
            "required": true
          },
          {
            "name": "path",
            "type": "str",
            "description": "笔记文件路径",
            "required": true
          }
        ],
        "returns": {
          "type": "str",
          "description": "返回'success'表示成功加载到IPython，返回其他错误日志表示失败"
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "save_note",
        "description": "保存笔记",
        "stable": true,
        "parameters": [
          {
            "name": "path",
            "type": "str",
            "description": "笔记文件路径",
            "required": true
          },
          {
            "name": "content",
            "type": "str",
            "description": "笔记内容",
            "required": true
          }
        ],
        "returns": {
          "type": "bool",
          "description": "保存是否成功"
        }
      },
      {
        "name": "save_textfile_safe",
        "description": "保存笔记,仅允许操作allow list路径下面的文件",
        "stable": true,
        "parameters": [
          {
            "name": "path",
            "type": "str",
            "description": "文件相对路径",
            "required": true
          },
          {
            "name": "content",
            "type": "str",
            "description": "文件内容",
            "required": true
          }
        ],
        "returns": {
          "type": "bool",
          "description": "保存是否成功"
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "patch_textfile_safe",
        "description": "保存笔记,仅允许操作allow list路径下面的文件",
        "stable": true,
        "parameters": [
          {
            "name": "path",
            "type": "str",
            "description": "文件相对路径",
            "required": true
          },
          {
            "name": "patch",
            "type": "str",
            "description": "文件内容",
            "required": true
          }
        ],
        "returns": {
          "type": "bool",
          "description": "保存是否成功"
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "query_note_by_name",
        "description": "查询笔记名称",
        "stable": true,
        "parameters": [
          {
            "name": "name_query",
            "type": "str",
            "description": "笔记名称查询字符串，模糊匹配",
            "required": true
          }
        ],
        "returns": {
          "type": "str",
          "description": "笔记相对路径，如果找到多个匹配项，则返回第一个匹配项的路径。若无匹配则为空字符串"
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "query_notes_by_text",
        "description": "查询笔记内容",
        "stable": true,
        "parameters": [
          {
            "name": "text_query",
            "type": "str",
            "description": "笔记内容查询字符串，模糊匹配",
            "required": true
          },
          {
            "name": "chunk_size",
            "type": "int",
            "description": "每个笔记块的字符数限制",
            "required": false
          },
          {
            "name": "limit",
            "type": "int",
            "description": "返回结果条数限制",
            "required": false
          },
          {
            "name": "regex",
            "type": "bool",
            "description": "是否使用正则表达式匹配",
            "required": false
          },
          {
            "name": "folder",
            "type": "str",
            "description": "查询的文件夹路径,默认为空,则从根目录开始查询",
            "required": false
          }
        ],
        "returns": {
          "type": "list",
          "description": "返回笔记相对路径列表，如果找到多个匹配项，则返回所有匹配项的路径。若无匹配则为空列表"
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "read_note",
        "description": "读取笔记内容",
        "stable": true,
        "parameters": [
          {
            "name": "path",
            "type": "str",
            "description": "笔记文件路径",
            "required": true
          }
        ],
        "returns": {
          "type": "str",
          "description": "返回笔记文本内容"
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "get_all_skills_summary",
        "description": "获取所有技能的概要信息列表，包括技能名称、描述、路径等基本信息",
        "stable": true,
        "parameters": [],
        "returns": {
          "type": "list",
          "description": "技能概要信息列表，每个元素包含 name、description、path 等字段"
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "get_skill_detail",
        "description": "获取单个技能的详细信息，包括完整的元数据、Markdown 内容、脚本和参考资料列表",
        "stable": true,
        "parameters": [
          {
            "name": "skill_name",
            "type": "str",
            "description": "技能名称（kebab-case 格式，如 'pdf-processing'）",
            "required": true
          }
        ],
        "returns": {
          "type": "dict",
          "description": "技能详细信息字典，包含 metadata、content、scripts、references 等字段"
        },
        "extra_data": {
          "enable_mcp": true
        }
      },
      {
        "name": "exec_note_in_ipython",
        "description": "执行笔记内容",
        "stable": true,
        "parameters": [
          {
            "name": "path",
            "type": "str",
            "description": "笔记文件路径",
            "required": true
          }
        ],
        "returns": {
          "type": "object",
          "description": "返回执行结果"
        },
        "extra_data": {
          "enable_mcp": true
        }
      }
    ]
  },
  "callbacks": {
    "on_load": "load_plugin",
    "on_unload": "unload_plugin"
  },
  "tabs": [
    {
      "name": "📝 快速笔记",
      "class": "QuickNotesTab",
      "position": 2
    }
  ]
}