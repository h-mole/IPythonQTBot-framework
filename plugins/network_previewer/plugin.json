{
  "name": "network_previewer",
  "description": "NetworkX 网络可视化插件 - 在浏览器中可视化展示 NetworkX 图",
  "version": "1.0.0",
  "author": "MyHelper Team",
  "main": "main",
  
  "dependencies": [
    {
      "name": "plugin:http_server",
      "version": ">=1.0.0",
      "required": true,
      "description": "Flask HTTP 服务器插件"
    }
  ],
  
  "exports": {
    "namespace": "network_previewer",
    "description": "NetworkX 图可视化 API",
    "methods": [
      {
        "name": "view_network",
        "description": "在浏览器中可视化展示 NetworkX 图",
        "stable": true,
        "parameters": [
          {
            "name": "graph",
            "type": "object",
            "description": "NetworkX 图对象",
            "required": true
          },
          {
            "name": "title",
            "type": "str",
            "description": "页面标题（可选）",
            "required": false
          },
          {
            "name": "options",
            "type": "dict",
            "description": "vis-network 配置选项（可选）",
            "required": false
          }
        ],
        "returns": {
          "type": "dict",
          "description": "包含 success(bool), url(str), error(str) 等字段"
        }
      }
    ]
  },
  
  "callbacks": {
    "on_load": "load_plugin",
    "on_unload": "unload_plugin"
  },
  
  "tabs": []
}
